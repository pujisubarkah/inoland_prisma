generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models in the public schema
model master_provinsi {
  id_provinsi   Int     @id @default(autoincrement())
  nama_provinsi String
  inolands      inolands[]
  provinsis     provinsis[]
  master_kabupaten master_kabupaten[]
  inovasis inovasis[]
  kabupatens kabupatens[]
  indeks_inovasi indeks_inovasi[]
}

model master_kabupaten {
  id            Int     @id @default(autoincrement())
  id_kabkot     Int     @unique
  id_provinsi   Int?    
  nama_kabkot   String

  master_provinsi master_provinsi? @relation(fields: [id_provinsi], references: [id_provinsi])
  inolands inolands[]
  inovasis inovasis[]
  kabupatens kabupatens[]
  
}

model sdgs {
  id     Int    @id @default(autoincrement())
  sdgs   String
  image  String
  inolands inolands[]
}

model beritas {
  id          Int     @id @default(autoincrement())
  likes       Int?    @default(0)
  title       String
  date        DateTime
  image_url   String
  deskripsi   String
}

model dokumens {
  id            Int     @id @default(autoincrement())
  nama          String
  link          String
  jenis_dokumen String
}

model inolands {
  id              Int     @id @default(autoincrement())
  id_provinsi     Int?    
  id_kabkot       Int?
  sdgs        Int?
  deskripsi       String?
  tahun           String?
  inovator        String?
  judul_inovasi   String?
  kld             String?
  urusan          String?

  master_provinsi   master_provinsi? @relation(fields: [id_provinsi], references: [id_provinsi])
  master_kabupaten  master_kabupaten? @relation(fields: [id_kabkot], references: [id_kabkot])
  sdgs_relasi       sdgs? @relation(fields: [sdgs], references: [id])
}

model provinsis {
  id           Int    @id @default(autoincrement())
  id_provinsi  Int    @unique
  nama         String
  svg_path     String
  Tahun_2019  String
  Tahun_2020  String
  Tahun_2021  String
  Tahun_2022  String
  Tahun_2023  String
  
  master_provinsi master_provinsi @relation(fields: [id_provinsi], references: [id_provinsi])
}

model pdflist {
  id            Int    @id @default(autoincrement())
  pdf_url       String
  pdf_judul     String
  pdf_kategori  String
  pdf_cover     String
  pdf_publisher String
}

model inovasis {
  id                 Int  @id @default(autoincrement())
  id_provinsi        Int?
  id_kabkot          Int?
  nama_inovasi       String
  penggagas          String
  deskripsi          String
  nama_instansi      String
  unit_instansi      String
  tahun_inisiasi     String
  tahun_implementasi String
  faktor_pendorong   String
  faktor_penghambat  String
  tahapan_proses     String
  output             String
  outcome            String
  manfaat            String
  prasyarat_replikasi String
  kontak             String
  sumber             String
  published_at       String
  updated_at         String
  created_by_id      String
  updated_by_id      String
  locale             String
  created_at         String
  document_id        String

  master_provinsi   master_provinsi? @relation(fields: [id_provinsi], references: [id_provinsi])
  master_kabupaten  master_kabupaten? @relation(fields: [id_kabkot], references: [id_kabkot])
}

model kabupatens {
  id         Int  @id @default(autoincrement())
  nama       String
  svg_path   String
  id_provinsi        Int?
  id_kabkot          Int?

  master_provinsi   master_provinsi? @relation(fields: [id_provinsi], references: [id_provinsi])
  master_kabupaten  master_kabupaten? @relation(fields: [id_kabkot], references: [id_kabkot])
}

model users {
  id              String @id @default(uuid())
  nama_lengkap    String
  email           String @unique
  password        String
  instansi        String?
  role_id         Int?
  is_verified     Boolean @default(false)  // Column for email verification
  verification_token String? // Token for email verification
  created_at      DateTime @default(now())
}

model inovasi_LAN {
   id         Int  @id @default(autoincrement())
  nama_inovasi    String
  produk_inovasi  String 
  nama_instansi   String
  deskripsi       String?
  image_link       String?
  created_at      DateTime @default(now())
}

model indeks_inovasi {
  id         Int  @id @default(autoincrement())
 id_provinsi Int
 id_kabkot Int
 indeks_tahun Int
 indeks_skor Float
 indeks_predikat String
 nama_kabkot String
 nama_prov String
 level String
 indeks_level String

master_provinsi   master_provinsi? @relation(fields: [id_provinsi], references: [id_provinsi])
}
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

model master_provinsi {
  id            Int    @id @default(autoincrement())
  id_provinsi   Int
  nama_provinsi String

  @@schema("public") // Tambahkan schema
}

model beritas {
  id            Int    @id @default(autoincrement())
  likes         Int?    @default(0) // Tambahkan default value
  title         String
  date          DateTime
  image_url     String
  deskripsi     String

  @@schema("public") // Tambahkan schema
}

model dokumens {
  id            Int    @id @default(autoincrement())
  nama         String    
  link         String
  jenis_dokumen          DateTime
  
  @@schema("public") // Tambahkan schema
}

